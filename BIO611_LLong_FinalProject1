combined <- clean_names(combined)
```

Performing a MANOVA to look at variables against breeds 
```{r}
manova_model <- manova(cbind(
  stranger_directed_aggression,
  dog_directed_aggression,
  stranger_directed_fear,
  dog_directed_fear,
  chasing,
  attachment_attention_seeking,
  separation_anxiety,
  touch_sensitivity,
  excitability
) ~ breed, data = combined)

summary(manova_model)
##determine which leads to significance 
summary.aov(manova_model)


#looking at cor matrix due to the extreme significance 
