  rename(`Attachment/Attention-seeking` = `Attachment/Attentio-seeking`)

#Check names 
names(alldogs1)
names(gsd1)
##add group names 
alldogs1$group <- "AllDogs"
gsd1$group <- "GermanShepherd"

#combine rows for 1 dataframe
#combined <- bind_rows(alldogs1, gsd1) # did not work because factors and numeric datasets 

#fixing data type
alldogs1 <- alldogs1 %>%
  mutate(across(-c(Breed, Group), ~ as.numeric(as.character(.))))
gsd1 <- gsd1 %>%
  mutate(across(-c(Breed, Group), ~ as.numeric(as.character(.))))
#now combine 
combined <- bind_rows(alldogs1, gsd1)


