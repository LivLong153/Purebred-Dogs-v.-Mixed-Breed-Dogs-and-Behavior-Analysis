Using logistic regression to determine if there is a difference across breeds for 2+ behaviors within the herding group (behavior 2+ is coded as 1 and all other possibilities as 0)

```{r}
behavior_vars1 <- c(
  "stranger_directed_aggression",
  "dog_directed_aggression",
  "separation_anxiety"
)

#making sure breed is a factor 
model_data$breed <- as.factor(model_data$Breed)

#adding german shepherds to model data 
model_data <- combined %>%
  filter(BreedGroup == "High-Drive Breeds" | breed == "German Shepherd") %>%
  
  mutate(across(all_of(behavior_vars1), ~ ifelse(. > 0, 1, 0))) %>%
  
  filter(if_all(all_of(behavior_vars1), ~ !is.na(.))) %>%
  
  mutate(
    behavior_sum = rowSums(across(all_of(behavior_vars1))),
    two_plus = ifelse(behavior_sum >= 2, 1, 0),
    breed = as.factor(breed) )
#setting germanshepherds as the reference data 
model_data$breed <- relevel(model_data$breed, ref = "German Shepherd")

#running the model 
model <- glm(two_plus ~ breed, data = model_data, family = binomial)
summary(model)

#converting to odds ratio 
exp(coef(model))
#adding confidence intervals 
exp(confint(model))

#table for results 
#changing name 
